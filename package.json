{
  "name": "kindle-digest",
  "version": "1.0.0",
  "description": "Single-user RSS-to-Kindle digest app backed by Inoreader",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "fetch-fonts": "tsx scripts/fetch-fonts.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.1",
    "@fastify/multipart": "^9.0.1",
    "rss-parser": "^4.2.3",
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "htmx.org": "^1.9.12",
    "jsdom": "^25.0.1",
    "jszip": "^3.10.1",
    "luxon": "^3.5.0",
    "nodemailer": "^6.9.16",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsdom": "^21.1.7",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^8.57.1",
    "jsqr": "^1.4.0",
    "nock": "^13.5.6",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
