# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
APP_BASE_URL=http://localhost:3000

# ─── Storage ──────────────────────────────────────────────────────────────
# SQLite database file. On Fly.io this lives on the mounted volume.
DATABASE_PATH=./data/kindle-digest.sqlite

# ─── SMTP (Send to Kindle) ────────────────────────────────────────────────
# The SMTP "from" address MUST be added to your Amazon Approved Personal
# Document E-mail List, or Kindle will silently reject the delivery.
# For Gmail: use an App Password (requires 2FA), not your account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# These can also be set in the Settings page (DB overrides env when present).
KINDLE_EMAIL=
DELIVERY_TIME=06:30
TIMEZONE=America/New_York

# ─── Feed fetching ────────────────────────────────────────────────────────
# Minimum visible-text length (chars) for a feed's own content to be treated
# as "full" before falling back to Readability.js. Tune to your feeds.
FULLTEXT_MIN_CHARS=1800
