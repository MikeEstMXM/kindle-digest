# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
# Public base URL of this app (used to build the Inoreader OAuth redirect URI)
APP_BASE_URL=http://localhost:3000

# ─── Storage ──────────────────────────────────────────────────────────────
# SQLite database file. On Fly.io this should live on the mounted volume.
DATABASE_PATH=./data/kindle-digest.sqlite

# ─── Secrets ──────────────────────────────────────────────────────────────
# 32-byte key (base64 or hex, 64 hex chars) used to encrypt OAuth tokens at
# rest with AES-256-GCM. Generate: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# ─── Inoreader OAuth2 ─────────────────────────────────────────────────────
# Create an app at https://www.inoreader.com/developers/
# Redirect URI must be exactly: ${APP_BASE_URL}/auth/callback
INOREADER_CLIENT_ID=
INOREADER_CLIENT_SECRET=

# ─── SMTP (Send to Kindle) ────────────────────────────────────────────────
# The SMTP "from" address MUST be added to your Amazon Approved Personal
# Document E-mail List, or Kindle will silently reject the delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# These can also be set in the Settings page (DB overrides env when present).
KINDLE_EMAIL=
DELIVERY_TIME=06:30
TIMEZONE=America/New_York

# Full-text detection: minimum extracted-text length (chars) for Inoreader's
# own content to be treated as "full" before falling back to Readability.
FULLTEXT_MIN_CHARS=1800
